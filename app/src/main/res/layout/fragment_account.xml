<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.account.AccountFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MedStock.Card.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_google_title"
                    android:textColor="?attr/medColorTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/account_google_summary"
                    android:textColor="?attr/medColorTextSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <TextView
                            android:id="@+id/account_avatar_label"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_account_avatar"
                            android:gravity="center"
                            android:textColor="?attr/medColorPrimaryText"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="S" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/account_avatar_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/account_google_avatar_content_description"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            app:shapeAppearanceOverlay="@style/Shape.MedStock.Circle"
                            app:strokeColor="?attr/medColorPrimaryDark"
                            app:strokeWidth="2dp"
                            tools:src="@tools:sample/avatars"
                            tools:visibility="visible" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/account_email_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/medColorTextPrimary"
                            android:textStyle="bold"
                            tools:text="syntax@example.com" />

                        <TextView
                            android:id="@+id/account_status_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_1"
                            android:textColor="?attr/medColorTextSecondary"
                            tools:text="Połączono z kontem Google" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/account_google_connect_button"
                    style="@style/Widget.MedStock.Button.CtaPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/account_google_connect_button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/account_google_disconnect_button"
                    style="@style/Widget.MedStock.Button.CtaDanger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/account_google_disconnect_button"
                    tools:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MedStock.Card.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_drive_title"
                    android:textColor="?attr/medColorTextPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/account_drive_summary"
                    android:textColor="?attr/medColorTextSecondary" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/account_drive_backup_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:text="@string/account_drive_switch_label"
                    android:textColor="?attr/medColorTextPrimary" />

                <TextView
                    android:id="@+id/account_drive_status_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:textColor="?attr/medColorTextSecondary"
                    tools:text="Kopia w Google Drive jest włączona." />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/account_drive_backup_now_button"
                    style="@style/Widget.MedStock.Button.CtaSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:text="@string/account_drive_backup_now_button"
                    android:textColor="?attr/medColorTextPrimary" />

                <ProgressBar
                    android:id="@+id/account_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/space_3"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
