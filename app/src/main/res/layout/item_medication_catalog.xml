<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.MedStock.Card.Primary"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/space_1"
    android:layout_marginBottom="@dimen/space_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <TextView
            android:id="@+id/text_medication_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/medColorTextPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_medication_common_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/medColorTextSecondary" />

        <TextView
            android:id="@+id/text_medication_collapsed_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            android:text="@string/medication_catalog_expand_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/medColorTextSecondary" />

        <TextView
            android:id="@+id/text_medication_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/medColorTextPrimary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_medication_leaflet"
                style="@style/Widget.MedStock.Button.CtaSupport"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_1"
                android:layout_weight="1"
                android:text="@string/medication_catalog_download_leaflet"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_medication_characteristics"
                style="@style/Widget.MedStock.Button.CtaSupport"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1"
                android:layout_weight="1"
                android:text="@string/medication_catalog_download_characteristics"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
