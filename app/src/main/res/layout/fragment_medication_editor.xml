<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/edit_text_medication_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/medication_name_hint"
        android:imeOptions="actionNext"
        android:inputType="textCapSentences" />

    <EditText
        android:id="@+id/edit_text_medication_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/medication_note_hint"
        android:imeOptions="actionDone"
        android:inputType="textCapSentences" />

    <Button
        android:id="@+id/button_save_medication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/medication_editor_add" />

</LinearLayout>
