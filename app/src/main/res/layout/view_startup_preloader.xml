<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/startup_preloader"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?medColorSurface"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/preloader_logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:contentDescription="@string/brand_strip_logo_desc"
            android:src="@drawable/logo_medstock" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_name_med"
                android:textColor="@color/preloader_brand_med"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_name_stock"
                android:textColor="@color/preloader_brand_stock"
                android:textSize="40sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/preloader_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:max="100"
            android:minHeight="10dp"
            android:progress="0"
            android:progressBackgroundTint="?medColorPrimarySoft"
            android:progressTint="?medColorPrimary" />

        <TextView
            android:id="@+id/preloader_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/preloader_status_init"
            android:textColor="?medColorTextPrimary"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
