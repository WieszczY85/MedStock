<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.settings.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MedStock.Card.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/space_4">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:contentDescription="@string/settings_theme_icon_description" android:src="@drawable/ic_dark_mode_black_24dp" app:tint="?attr/medColorTextSecondary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/space_2" android:layout_weight="1" android:text="@string/settings_theme_title" android:textColor="?attr/medColorTextPrimary" android:textStyle="bold" />
                    <ImageButton android:id="@+id/settings_theme_help" style="?attr/borderlessButtonStyle" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/settings_help_for_theme" android:src="@drawable/ic_help_small_24" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_theme_summary_short" android:textColor="?attr/medColorTextSecondary" />
                <RadioGroup
                    android:id="@+id/settings_theme_mode_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:background="@drawable/bg_settings_option_group"
                    android:checkedButton="@id/settings_theme_auto_button"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_theme_auto_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_theme_auto" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_theme_on_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_theme_on" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_theme_off_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_theme_off" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Widget.MedStock.Card.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_3">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/space_4">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:contentDescription="@string/settings_palette_icon_description" android:src="@drawable/ic_gallery_black_24dp" app:tint="?attr/medColorTextSecondary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/space_2" android:layout_weight="1" android:text="@string/settings_palette_title" android:textColor="?attr/medColorTextPrimary" android:textStyle="bold" />
                    <ImageButton android:id="@+id/settings_palette_help" style="?attr/borderlessButtonStyle" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/settings_help_for_palette" android:src="@drawable/ic_help_small_24" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_palette_summary_short" android:textColor="?attr/medColorTextSecondary" />
                <RadioGroup
                    android:id="@+id/settings_palette_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:background="@drawable/bg_settings_option_group"
                    android:checkedButton="@id/settings_palette_green_button"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_palette_green_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_palette_green"
                        app:buttonTint="@color/palette_preview_green" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_palette_ocean_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_palette_ocean"
                        app:buttonTint="@color/palette_preview_ocean" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_palette_berry_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_palette_berry"
                        app:buttonTint="@color/palette_preview_berry" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_palette_sage_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_palette_sage"
                        app:buttonTint="@color/palette_preview_sage" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/settings_palette_lavender_button"
                        style="@style/Widget.MedStock.RadioButton.SettingsOption"
                        android:text="@string/settings_palette_lavender"
                        app:buttonTint="@color/palette_preview_lavender" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MedStock.Card.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/settings_catalog_view_icon_description"
                        android:src="@drawable/ic_list_black_24dp"
                        app:tint="?attr/medColorTextSecondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_2"
                        android:layout_weight="1"
                        android:text="@string/settings_catalog_view_title"
                        android:textColor="?attr/medColorTextPrimary"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_catalog_view_summary"
                    android:textColor="?attr/medColorTextSecondary" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/settings_show_inactive_pharmacies_switch"
                    style="@style/Widget.MedStock.Switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:minHeight="48dp"
                    android:text="@string/settings_show_inactive_pharmacies"
                    android:textColor="?attr/medColorTextPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Widget.MedStock.Card.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_3">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/space_4">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:contentDescription="@string/settings_language_icon_description" android:src="@drawable/ic_settings_black_24dp" app:tint="?attr/medColorTextSecondary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/space_2" android:layout_weight="1" android:text="@string/settings_language_title" android:textColor="?attr/medColorTextPrimary" android:textStyle="bold" />
                    <ImageButton android:id="@+id/settings_language_help" style="?attr/borderlessButtonStyle" android:layout_width="40dp" android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/settings_help_for_language" android:src="@drawable/ic_help_small_24" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_language_summary_short" android:textColor="?attr/medColorTextSecondary" />
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_2" android:scrollbars="none">
                    <com.google.android.material.button.MaterialButtonToggleGroup android:id="@+id/settings_language_mode_group" android:layout_width="wrap_content" android:layout_height="wrap_content" app:checkedButton="@id/settings_language_auto_button" app:selectionRequired="true" app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton android:id="@+id/settings_language_auto_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_auto" android:textAllCaps="false" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/settings_language_pl_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_polish_short" android:textAllCaps="false" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/settings_language_en_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_english_short" android:textAllCaps="false" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/settings_language_de_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_german_short" android:textAllCaps="false" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/settings_language_fr_button" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/settings_language_french_short" android:textAllCaps="false" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView android:id="@+id/settings_info_card" style="@style/Widget.MedStock.Card.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_3" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/space_4">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_info_title" android:textColor="?attr/medColorTextPrimary" android:textStyle="bold" />
                <TextView android:id="@+id/settings_app_name_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_2" android:textColor="?attr/medColorTextSecondary" tools:text="MedStock" />
                <TextView android:id="@+id/settings_author_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="?attr/medColorTextSecondary" tools:text="by WieszczY" />
                <TextView android:id="@+id/settings_version_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="?attr/medColorTextSecondary" tools:text="Version: 1.0" />
                <TextView android:id="@+id/settings_last_update_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="?attr/medColorTextSecondary" tools:text="Database: 2026-05-26" />
                <TextView android:id="@+id/settings_db_size_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="?attr/medColorTextSecondary" tools:text="18 MB" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:id="@+id/settings_developer_actions" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_3" android:orientation="vertical" android:visibility="gone" tools:visibility="visible">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings_developer_title" android:textColor="?attr/medColorTextPrimary" android:textStyle="bold" />
            <com.google.android.material.button.MaterialButton android:id="@+id/settings_force_update_button" style="@style/Widget.MedStock.Button.CtaPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_2" android:text="@string/settings_force_update_button" />
            <com.google.android.material.button.MaterialButton android:id="@+id/settings_export_database_button" style="@style/Widget.MedStock.Button.CtaPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_2" android:text="@string/settings_export_database_button" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
