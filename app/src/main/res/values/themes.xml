<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MedStock" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/green_500</item>
        <item name="colorPrimaryVariant">@color/title_bar_background</item>
        <item name="colorOnPrimary">@color/green_900</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/green_200</item>
        <item name="colorSecondaryVariant">@color/green_700</item>
        <item name="colorOnSecondary">@color/green_900</item>
        <item name="colorSurface">@color/surface_light</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.MedStock.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.MedStock.Ringing" parent="Theme.MedStock.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.MedStock.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="colorControlNormal">@color/top_app_bar_content</item>
    </style>

    <style name="Theme.MedStock.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
