<resources>
    <style name="Theme.MedStock" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Standard Material Attributes -->
        <item name="colorPrimary">?attr/medColorPrimary</item>
        <item name="colorPrimaryVariant">?attr/medColorTitleBar</item>
        <item name="colorOnPrimary">?attr/medColorPrimaryText</item>
        <item name="colorSecondary">?attr/medColorPrimarySoft</item>
        <item name="colorSecondaryVariant">?attr/medColorPrimaryDark</item>
        <item name="colorOnSecondary">?attr/medColorTextPrimary</item>
        <item name="colorSurface">?attr/medColorSurface</item>
        <item name="colorOnSurface">?attr/medColorTextPrimary</item>
        <item name="android:colorBackground">?attr/medColorSurface</item>
        <item name="colorOnBackground">?attr/medColorTextPrimary</item>
        <item name="colorAccent">?attr/medColorPrimary</item>
        <item name="android:colorAccent">?attr/medColorPrimary</item>

        <!-- Window Attributes -->
        <item name="android:windowBackground">?attr/medColorSurface</item>
        <item name="android:statusBarColor">?attr/medColorTitleBar</item>

        <!-- Custom medColor attributes (Default Green Palette) -->
        <item name="medColorPrimary">@color/green_500</item>
        <item name="medColorPrimaryDark">@color/green_700</item>
        <item name="medColorPrimaryText">@color/green_900</item>
        <item name="medColorPrimarySoft">@color/green_200</item>
        <item name="medColorSurface">@color/surface_light</item>
        <item name="medColorSurfaceCard">@color/surface_card</item>
        <item name="medColorSurfaceCardSoft">@color/surface_card_soft</item>
        <item name="medColorTextPrimary">@color/text_primary</item>
        <item name="medColorTextSecondary">@color/text_secondary</item>
        <item name="medColorTopBar">@color/top_app_bar_background</item>
        <item name="medColorTopBarContent">@color/top_app_bar_content</item>
        <item name="medColorTitleBar">@color/title_bar_background</item>
        <item name="medColorTitleBarText">@color/title_bar_text</item>
        <item name="medColorBottomBar">@color/bottom_nav_background</item>
        <item name="medColorBottomSelected">@color/bottom_nav_selected</item>
        <item name="medColorBottomUnselected">@color/bottom_nav_unselected</item>
    </style>

    <style name="Theme.MedStock.NoActionBar" parent="Theme.MedStock">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.MedStock.Ringing" parent="Theme.MedStock.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

