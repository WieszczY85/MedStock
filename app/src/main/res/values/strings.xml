    <string name="help_data_safety_title">Data safety</string>
    <string name="settings_privacy_title">Privacy and Data safety</string>
    <string name="settings_privacy_summary">MedStock is a home inventory manager for medicinal products. It does not diagnose, treat, recommend medicines, or set dosage.</string>
    <string name="settings_privacy_local_data_title">Data stored on this device</string>
    <string name="settings_privacy_local_data_body">The app stores the medicinal products you enter, package/strength details, active substance, stock amount, user-entered dosage, expiry dates, stock alert thresholds, reminders, dose events, app preferences, and catalog databases used to match public medicine registry data.</string>
    <string name="settings_privacy_cloud_backup_title">Google account and Drive backup</string>
    <string name="settings_privacy_cloud_backup_body">If you connect a Google account, MedStock stores the selected email locally and may fetch the account avatar. If you enable Google Drive backup, the app uploads a JSON backup with your products, user-entered dosage, reminders, stock data, alert settings, and preferences to the appDataFolder area of your Google Drive. Drive backup is optional and can be disabled from the Account screen.</string>
    <string name="settings_privacy_medical_disclaimer_title">Medical disclaimer</string>
    <string name="settings_privacy_medical_disclaimer_body">MedStock is not a medical device. It does not provide medical advice, verify whether your dosage is correct, or replace advice from a doctor or pharmacist. You are responsible for the data you enter and for following professional medical instructions.</string>
    <string name="settings_privacy_controls_title">Your controls</string>
    <string name="settings_privacy_controls_body">You can edit or delete medicines and reminders in the app, disable Drive backup, disconnect the Google account, export the local database, clear app data in Android settings, and remove MedStock backup data from Google Drive. MedStock does not use advertising, analytics, or sell personal data.</string>
