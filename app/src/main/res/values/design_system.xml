<resources>

    <style name="Shape.MedStock.Rounded.Small" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_sm</item>
    </style>

    <style name="Shape.MedStock.Rounded.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="Shape.MedStock.Rounded.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

    <style name="Shape.MedStock.Circle" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.MedStock.Card.Primary" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">?attr/medColorSurfaceCard</item>
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">@dimen/card_elevation_mid</item>
        <item name="strokeColor">?attr/medColorPrimarySoft</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
    </style>

    <style name="Widget.MedStock.Card.Secondary" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">?attr/medColorSurfaceCardSoft</item>
        <item name="cardCornerRadius">@dimen/radius_sm</item>
        <item name="cardElevation">@dimen/card_elevation_low</item>
        <item name="strokeColor">?attr/medColorPrimarySoft</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
    </style>

    <style name="Widget.MedStock.Card.Alert" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">@dimen/card_elevation_mid</item>
        <item name="strokeColor">?attr/medColorPrimary</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="Widget.MedStock.Button.CtaPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/cta_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">?attr/medColorPrimary</item>
        <item name="android:textColor">?attr/medColorPrimaryText</item>
        <item name="shapeAppearance">@style/Shape.MedStock.Rounded.Medium</item>
    </style>

    <style name="Widget.MedStock.Button.CtaSupport" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/cta_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/medColorPrimarySoft</item>
        <item name="strokeColor">?attr/medColorPrimaryDark</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
        <item name="android:textColor">?attr/medColorTextPrimary</item>
        <item name="shapeAppearance">@style/Shape.MedStock.Rounded.Medium</item>
    </style>

    <style name="Widget.MedStock.RadioButton.SettingsOption" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">@dimen/space_3</item>
        <item name="android:paddingEnd">@dimen/space_3</item>
        <item name="android:textColor">?attr/medColorTextPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="buttonTint">?attr/medColorPrimary</item>
    </style>

    <style name="Widget.MedStock.Button.CtaDanger" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">@dimen/cta_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/cta_danger_bg</item>
        <item name="android:textColor">@color/cta_danger_text</item>
        <item name="shapeAppearance">@style/Shape.MedStock.Rounded.Small</item>
    </style>

</resources>
